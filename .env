# PMS Multi-Tenant SaaS Platform
# Copy this file to .env and fill in your values

# Application
NODE_ENV=production
PORT=5000

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pms
DB_USER=postgres
DB_PASSWORD=postgres
DB_POOL_SIZE=10
DB_IDLE_TIMEOUT=30000

# JWT
JWT_SECRET=change-this-in-production-to-a-secure-random-key

# Frontend URL
